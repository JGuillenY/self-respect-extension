{
  "name": "Self Respect",
  "description": "Helps you avoid sites that don't align with your self-respect goals by redirecting to healthier alternatives.",
  "version": "1.0.0",
  "manifest_version": 3,
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "js": ["dist/content.js"],
      "matches": ["<all_urls>"],
      "run_at": "document_start"
    }
  ],
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Self Respect Settings"
  },
  "web_accessible_resources": [
    {
      "resources": ["src/constants.ts"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
